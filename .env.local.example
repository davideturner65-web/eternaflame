NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Cloudflare Turnstile — get keys at dash.cloudflare.com > Turnstile
# Site key is public (NEXT_PUBLIC_), secret key stays server-side only
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Canonical site URL — used for magic link redirect
NEXT_PUBLIC_SITE_URL=https://eternaflame.org

# Cron job protection — Vercel sends this as Authorization: Bearer <secret>
CRON_SECRET=generate-with-openssl-rand-hex-32
